struct Player {
    float hp = 100, maxHp = 100; 
    float guard = 0;
    bool godShield = false;
    int regenTurn = 0;
    float lastTurnDmg = 0; 

    vector<Card> deck;
    vector<Card> hand;

    void draw(int n) {
        while (n-- > 0 && !deck.empty()) {
            hand.push_back(deck.back());
            deck.pop_back();
        }
    }

    void heal(float p) {
        hp += p;
        if (hp > maxHp) hp = maxHp;
    }

    void takeDamage(float dmg, bool ignoreGuard = false) {
        if (godShield) {
            godShield = false; 
            return;
        }
        if (!ignoreGuard) {
            dmg *= (1.0f - guard);
        }
        hp -= dmg;
        lastTurnDmg += dmg; 
        if (hp < 0) hp = 0;
    }

    void resetStatus() {
        guard = 0;
        regenTurn = 0;
        godShield = false;
    }
};//

struct Game {
    Player p[2];
    int cur = 0;
    int usedCard = 0;
    bool usedSpecial = false;

    void initDeck(Player& pl) {
        vector<Card> base;
        
        for (int i = 1; i <= 9; i++) {
            base.push_back({ (CardType)i });
            base.push_back({ (CardType)i });
            base.push_back({ (CardType)i });
        }
        
        for (int i = 10; i <= 12; i++) {
            base.push_back({ (CardType)i });
        }
        
        for (int i = 10; i <= 13; i++) {
            base.push_back({ (CardType)i });            
        }
       
        random_device rd;
        mt19937 g(rd());
        shuffle(base.begin(), base.end(), g);
        pl.deck = base;
    }

    void startGame() {
        for (int i = 0; i < 2; i++) {
            initDeck(p[i]);
            p[i].draw(5); 
        }
        cur = 0;
        startTurn();
    }

    void startTurn() {
        Player& me = p[cur];
        
        usedCard = 0;
        usedSpecial = false;
        
        
        me.guard = 0; 
        me.lastTurnDmg = 0; 

        
        if (me.regenTurn > 0) {
            me.heal(me.maxHp * 0.05f);
            me.regenTurn--;
        }

        
        me.draw(2);
    }

    bool isSpecial(CardType t) {
        return (int)t >= 10;
    }

    void apply(Card c) {
        Player& me = p[cur];
        Player& en = p[1 - cur];

        switch (c.type) {
            case CardType::LightAttack:
                en.takeDamage(en.maxHp * 0.10f);
                break;
            case CardType::HeavyAttack:
                en.takeDamage(en.maxHp * 0.20f);
                break;
            case CardType::HealSmall:
                me.heal(me.maxHp * 0.10f);
                break;
            case CardType::HealBig:
                me.heal(me.maxHp * 0.20f);
                break;
            case CardType::GuardSmall:
               
                me.guard = max(me.guard, 0.25f);
                break;
            case CardType::GuardBig:
                me.guard = max(me.guard, 0.50f);
                break;
            case CardType::LifeSteal:
                en.takeDamage(en.maxHp * 0.15f);
                me.heal(me.maxHp * 0.10f);
                break;
            case CardType::Regen:
                me.regenTurn = 3;
                break;
            case CardType::Pierce:
                en.takeDamage(en.maxHp * 0.15f, true);
                break;
            case CardType::Reset:
                en.resetStatus();
                break;
            case CardType::Death:
                en.takeDamage(en.maxHp * 0.30f);
                me.takeDamage(me.maxHp * 0.10f);
                break;
            case CardType::GodShield:
                me.godShield = true;
                me.heal(me.lastTurnDmg);
                break;
            case CardType::Nuke:
                en.takeDamage(en.maxHp * 0.50f, true); 
                me.takeDamage(me.maxHp * 0.50f, true); 
                break;    
        }
    }//

    void showStatus() {
        if (cur==0){
            cout << "\033[1;31m"<<"\n\n\n=====================================================================================================================================================================\033[0m"<<"\n";
        cout << "\033[1;31m"<<"                                                                  PLAYER " << cur + 1 << " TURN"<<"\033[0m"<<"\n";
        cout << "\033[1;31m"<<"=====================================================================================================================================================================\033[0m"<<"\n";
        }
        else{cout << "\033[1;34m"<<"\n\n\n=====================================================================================================================================================================\033[0m"<<"\n";
       cout << "\033[1;34m"<<"                                                                  PLAYER " << cur + 1 << " TURN"<<"\033[0m"<<"\n";
        cout << "\033[1;34m"<<"=====================================================================================================================================================================\033[0m"<<"\n";
        }
        cout << " " << "\n";
        cout << "\033[1;31m[Player 1]\033[0m HP: " << p[0].hp << "% | Shield: " << (p[0].godShield ? "GOD " : "") << (p[0].guard * 100) << "% | Regen: " << p[0].regenTurn << " | Deck: " << p[0].deck.size() << "\n";
        cout << "\033[1;34m[Player 2]\033[0m HP: " << p[1].hp << "% | Shield: " << (p[1].godShield ? "GOD " : "") << (p[1].guard * 100) << "% | Regen: " << p[1].regenTurn << " | Deck: " << p[1].deck.size() << "\n";
        cout << " " << "\n";
        if (cur==0){
            cout <<  "\033[1;31m"<<"-------------------------------------------------------\033[0m"<<"\n";
        }
        else{cout << "\033[1;34m"<<"-------------------------------------------------------\033[0m"<<"\n";}
        cout << "\033[33mYour Hand (\033[0m" << p[cur].hand.size()-1 << " cards\033[33m):\033[0m\n";
        cout << " " << "\n";

        for (int i = 1; i < p[cur].hand.size(); i++) {
            CardType t = p[cur].hand[i].type;
            cout << "  [" << i << "] " << cardName(t) << "\n         " << cardDesc(t) << "\n";
        
        }
        if (cur==0){
            cout <<  "\033[1;31m"<<"-------------------------------------------------------\033[0m"<<"\n";
        }
        else{cout << "\033[1;34m"<<"-------------------------------------------------------\033[0m"<<"\n";}
    }

    void playTurn() {
        while (usedCard < 2 && !p[cur].hand.empty()) {
            showStatus();
            cout << " " << "\n";
            cout << "Cards played this turn: " << usedCard << "/2\n";
            cout << "Choose a card to play (1 to " << p[cur].hand.size()-1 << "), or 0 to End Turn: ";
            cout << " ";
            int idx; 
            
            
            if (!(cin >> idx)) {
                cin.clear();
                cin.ignore(10000, '\n');
                cout << " Invalid input. Please enter a number.\n";
                continue;
            }

            if (idx == 0) break; 
            
            if (idx < 0 || idx >= p[cur].hand.size()) {
                cout << " Invalid card index!\n";
                continue;
            }

            Card c = p[cur].hand[idx];
            if (isSpecial(c.type) && usedSpecial) {
                cout << " You can only use 1 Special Card per turn!\n";
                continue;
            }

            // แสดงผลว่าใช้การ์ดอะไร
            cout << "\n>>> Player " << cur + 1 << " used [" << cardName(c.type) << "] <<<\n";
            
            apply(c);
            
            if (isSpecial(c.type)) usedSpecial = true;
            usedCard++;
            
            // ลบการ์ดที่ใช้แล้วออกจากมือ
            p[cur].hand.erase(p[cur].hand.begin() + idx);
            
            // เช็คว่ามีคนตายระหว่างเทิร์นหรือไม่
            if (p[0].hp <= 0 || p[1].hp <= 0) break;
        }

        // สลับฝั่งเล่น
        cur = 1 - cur;
        if (!isEnd()) {
            startTurn();
        }
    }

    bool isEnd() {
        // เกมจบเมื่อ HP ฝั่งใดฝั่งหนึ่งหมด หรือ การ์ดบนมือฝั่งใดฝั่งหนึ่งหมด
        return p[0].hp <= 0 || p[1].hp <= 0 || p[0].hand.empty() || p[1].hand.empty();
    }

    void result() {
        cout << "\n=====================================================================================================================================================================\n";
        cout << "                                                                          \033[5;31m*\033[0m\033[5;32m*\033[0m\033[5;34m*\033[1;33mGAME OVER\033[0m\033[5;34m*\033[0m\033[5;32m*\033[0m\033[5;31m*\033[0m\n";
        cout << "=====================================================================================================================================================================\n";
        cout << " " << "\n";
        cout <<  "\033[1;31m"<<"Player 1 HP: " << p[0].hp << "%"<<"\033[0m"<<"\n";
        cout << "\033[1;34m"<<"Player 2 HP: " << p[1].hp << "%"<<"\033[0m"<<"\n";

        if (p[0].hp > p[1].hp) cout << "\033[1;31m"<<" Player 1 Wins!"<<"\033[0m"<<"\n";
        else if (p[1].hp > p[0].hp) cout <<"\033[1;34m"<< " Player 2 Wins!"<<"\033[0m"<<"\n";
        else cout << "\033[1;32m"<<" Tie!\n"<<"\033[0m"<<"\n";
    }
};

